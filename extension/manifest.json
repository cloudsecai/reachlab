{
  "manifest_version": 3,
  "name": "LinkedIn Analytics Collector",
  "version": "0.1.0",
  "description": "Collects your LinkedIn post analytics and stores them locally",
  "permissions": ["alarms", "cookies", "storage", "tabs", "webNavigation"],
  "host_permissions": ["*://*.linkedin.com/*", "http://localhost:3210/*"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/analytics/*"],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  }
}
